{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "auto-manual-injector",
            "type": "command",
            "command": "node .gemini/hooks/inject-manual.js"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "name": "note-validator",
            "type": "command",
            "command": "node .gemini/hooks/validate-note.js"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "create_note",
        "hooks": [
          {
            "name": "anki-safety-check",
            "type": "command",
            "command": "node .gemini/hooks/validate-anki.js"
          }
        ]
      },
      {
        "matcher": "batch_create_notes",
        "hooks": [
          {
            "name": "anki-batch-safety-check",
            "type": "command",
            "command": "node .gemini/hooks/validate-anki.js"
          }
        ]
      }
    ]
  },
  "hooksConfig": {
    "enabled": true,
    "disabled": []
  }
}
